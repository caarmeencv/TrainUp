<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_card_white"
    android:elevation="3dp"
    android:orientation="horizontal"
    android:padding="14dp">

    <ImageView
        android:id="@+id/imgUsuario"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginEnd="14dp"
        android:background="#EEEEEE"
        android:scaleType="centerCrop"
        android:src="@drawable/logo_trainup" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtNombreUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nombre usuario"
            android:textColor="#111111"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtEmailUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="email@email.com"
            android:textColor="#777777"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtTelefonoUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="Teléfono"
            android:textColor="#777777"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtPlanUsuario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Plan: Sin plan"
            android:textColor="#FF2D7A"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnDesapuntar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:backgroundTint="#FF2D7A"
            android:text="Desapuntar"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</LinearLayout>