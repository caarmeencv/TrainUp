<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Configuración"
            android:textColor="#111111"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ajustes de tu cuenta y aplicación"
            android:textColor="#777777"
            android:textSize="16sp"
            android:layout_marginTop="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginTop="28dp">

            <TextView
                android:text="Cuenta"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#111111"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/btnEditarPerfil"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="16dp"
                android:text="Editar perfil"
                android:textAllCaps="false"
                android:textSize="17sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF2D7A" />

            <Button
                android:id="@+id/btnCambiarPassword"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="12dp"
                android:text="Cambiar contraseña"
                android:textAllCaps="false"
                android:textSize="17sp"
                android:textColor="#111111"
                android:backgroundTint="#EEEEEE" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginTop="18dp">

            <TextView
                android:text="Preferencias"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#111111"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <CheckBox
                android:id="@+id/checkNotificaciones"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Activar notificaciones"
                android:textSize="16sp"
                android:textColor="#111111"
                android:layout_marginTop="14dp" />

            <CheckBox
                android:id="@+id/checkRecordatorios"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Recordatorios de clases"
                android:textSize="16sp"
                android:textColor="#111111" />

            <CheckBox
                android:id="@+id/checkGuardarSesion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mantener sesión iniciada"
                android:textSize="16sp"
                android:textColor="#111111" />
        </LinearLayout>

        <Button
            android:id="@+id/btnCerrarSesion"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="28dp"
            android:text="Cerrar sesión"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#222222" />

        <Button
            android:id="@+id/btnEliminarCuenta"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="30dp"
            android:text="Eliminar cuenta"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#C62828" />

    </LinearLayout>
</ScrollView>