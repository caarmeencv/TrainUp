<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card_soft_pink"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/txtNombreClase"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pilates"
        android:textColor="#111111"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtFechaHora"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="2026-06-12 · 18:00"
        android:textColor="#333333"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/txtInfoClase"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Monitor: Carmen · Sala: 1"
        android:textColor="#555555"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/txtReservasClase"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_button_pink"
        android:paddingStart="14dp"
        android:paddingTop="7dp"
        android:paddingEnd="14dp"
        android:paddingBottom="7dp"
        android:text="Reservas: 0/20"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>