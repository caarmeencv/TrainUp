<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clases"
            android:textColor="#111111"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reserva tus clases favoritas"
            android:textColor="#777777"
            android:textSize="16sp"
            android:layout_marginTop="6dp" />

        <!-- Buscar -->
        <EditText
            android:id="@+id/etBuscarClase"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="24dp"
            android:hint="Buscar clase"
            android:padding="14dp"
            android:inputType="text"
            android:background="@android:drawable/edit_text" />

        <!-- Clase 1 -->
        <LinearLayout
            android:id="@+id/cardClase1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card"
            android:padding="14dp"
            android:layout_marginTop="24dp">

            <ImageView
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:src="@drawable/yoga"
                android:scaleType="centerCrop"
                android:contentDescription="Imagen clase" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Yoga"
                    android:textColor="#111111"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fit Center"
                    android:textColor="#666666"
                    android:textSize="15sp"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hoy · 18:00 - 19:00"
                    android:textColor="#777777"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />

                <Button
                    android:id="@+id/btnReservar1"
                    android:layout_width="wrap_content"
                    android:layout_height="45dp"
                    android:text="Reservar"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#FF2D7A"
                    android:layout_marginTop="10dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Clase 2 -->
        <LinearLayout
            android:id="@+id/cardClase2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card"
            android:padding="14dp"
            android:layout_marginTop="16dp">

            <ImageView
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:src="@drawable/spining"
                android:scaleType="centerCrop"
                android:contentDescription="Imagen clase" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Spinning"
                    android:textColor="#111111"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Urban Gym"
                    android:textColor="#666666"
                    android:textSize="15sp"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mañana · 19:30 - 20:30"
                    android:textColor="#777777"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />

                <Button
                    android:id="@+id/btnReservar2"
                    android:layout_width="wrap_content"
                    android:layout_height="45dp"
                    android:text="Reservar"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#FF2D7A"
                    android:layout_marginTop="10dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Clase 3 -->
        <LinearLayout
            android:id="@+id/cardClase3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card"
            android:padding="14dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="30dp">

            <ImageView
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:src="@drawable/crosstraining"
                android:scaleType="centerCrop"
                android:contentDescription="Imagen clase" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cross Training"
                    android:textColor="#111111"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Elite Fitness Club"
                    android:textColor="#666666"
                    android:textSize="15sp"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Viernes · 17:00 - 18:00"
                    android:textColor="#777777"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />

                <Button
                    android:id="@+id/btnReservar3"
                    android:layout_width="wrap_content"
                    android:layout_height="45dp"
                    android:text="Reservar"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#FF2D7A"
                    android:layout_marginTop="10dp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>