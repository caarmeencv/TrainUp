<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/txtNombrePlan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Plan Mensual"
        android:textColor="#111111"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtDescripcionPlan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Acceso completo al gimnasio durante un mes."
        android:textColor="#777777"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/txtPrecioPlan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="29.99 €"
        android:textColor="#FF2D7A"
        android:textSize="24sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnSeleccionarPlan"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="#FF2D7A"
        android:text="Seleccionar plan"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

</LinearLayout>