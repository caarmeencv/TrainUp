<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Crear rutina"
            android:textColor="#111111"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Diseña tu entrenamiento personalizado"
            android:textColor="#777777"
            android:textSize="16sp"
            android:layout_marginTop="6dp" />

        <!-- Nombre rutina -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre de la rutina"
            android:textColor="#111111"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="28dp" />

        <EditText
            android:id="@+id/etNombreRutina"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="10dp"
            android:hint="Ej: Pierna completa"
            android:padding="14dp"
            android:background="@android:drawable/edit_text" />

        <!-- Días -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Días por semana"
            android:textColor="#111111"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp" />

        <EditText
            android:id="@+id/etDias"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="10dp"
            android:hint="Ej: 4"
            android:inputType="number"
            android:padding="14dp"
            android:background="@android:drawable/edit_text" />

        <!-- Ejercicio -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ejercicio"
            android:textColor="#111111"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp" />

        <EditText
            android:id="@+id/etEjercicio"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="10dp"
            android:hint="Ej: Sentadilla"
            android:padding="14dp"
            android:background="@android:drawable/edit_text" />

        <!-- Series -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Series"
            android:textColor="#111111"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp" />

        <EditText
            android:id="@+id/etSeries"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="10dp"
            android:hint="Ej: 4"
            android:inputType="number"
            android:padding="14dp"
            android:background="@android:drawable/edit_text" />

        <!-- Repeticiones -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Repeticiones"
            android:textColor="#111111"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp" />

        <EditText
            android:id="@+id/etRepeticiones"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="10dp"
            android:hint="Ej: 12"
            android:inputType="number"
            android:padding="14dp"
            android:background="@android:drawable/edit_text" />

        <!-- Peso -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Peso (kg)"
            android:textColor="#111111"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp" />

        <EditText
            android:id="@+id/etPeso"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="10dp"
            android:hint="Ej: 60"
            android:inputType="numberDecimal"
            android:padding="14dp"
            android:background="@android:drawable/edit_text" />

        <!-- Botón añadir -->
        <Button
            android:id="@+id/btnAgregarEjercicio"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="28dp"
            android:text="Añadir ejercicio"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#222222" />

        <!-- Botón guardar -->
        <Button
            android:id="@+id/btnGuardarRutina"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="16dp"
            android:text="Guardar rutina"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF2D7A"
            android:layout_marginBottom="30dp" />

    </LinearLayout>

</ScrollView>