<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true"
    tools:context=".cliente.EditProfileActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Editar perfil"
            android:textColor="#111111"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Actualiza tus datos personales"
            android:textColor="#666666"
            android:textSize="16sp" />

        <ImageView
            android:id="@+id/imgPerfilEditar"
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="30dp"
            android:background="@drawable/bg_card_white"
            android:contentDescription="Imagen de perfil"
            android:padding="18dp"
            android:scaleType="centerCrop"
            android:src="@drawable/logo_trainup" />

        <Button
            android:id="@+id/btnCambiarImagenPerfil"
            android:layout_width="180dp"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="14dp"
            android:backgroundTint="#000000"
            android:text="Cambiar imagen"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="Nombre"
            android:textColor="#111111"
            android:textSize="15sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etNombreEditar"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#FF2D7A"
            android:hint="Introduce tu nombre"
            android:inputType="textPersonName"
            android:textColor="#111111"
            android:textColorHint="#999999"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Apellidos"
            android:textColor="#111111"
            android:textSize="15sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etApellidosEditar"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#FF2D7A"
            android:hint="Introduce tus apellidos"
            android:inputType="textPersonName"
            android:textColor="#111111"
            android:textColorHint="#999999"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Email"
            android:textColor="#111111"
            android:textSize="15sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etEmailEditar"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#FF2D7A"
            android:hint="Introduce tu email"
            android:inputType="textEmailAddress"
            android:textColor="#111111"
            android:textColorHint="#999999"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Teléfono"
            android:textColor="#111111"
            android:textSize="15sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etTelefonoEditar"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#FF2D7A"
            android:hint="Introduce tu teléfono"
            android:inputType="phone"
            android:textColor="#111111"
            android:textColorHint="#999999"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Fecha de nacimiento"
            android:textColor="#111111"
            android:textSize="15sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etFechaNacimientoEditar"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#FF2D7A"
            android:hint="AAAA-MM-DD"
            android:inputType="date"
            android:textColor="#111111"
            android:textColorHint="#999999"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Género"
            android:textColor="#111111"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spGeneroEditar"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#FF2D7A"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <Button
            android:id="@+id/btnGuardarPerfil"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="36dp"
            android:backgroundTint="#FF2D7A"
            android:text="Guardar cambios"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnCancelarEditarPerfil"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="14dp"
            android:backgroundTint="#000000"
            android:text="Cancelar"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>