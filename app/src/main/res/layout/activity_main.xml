<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF7FB"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <!-- Barra superior -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnMenu"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_menu_pink"
                android:gravity="center"
                android:text="☰"
                android:textColor="#111111"
                android:textSize="34sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="TrainUp"
                android:textColor="#FF2D7A"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:gravity="center"
                android:text="🔔"
                android:textSize="28sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="#FFD6E5" />

        <!-- Saludo -->
        <TextView
            android:id="@+id/txtSaludo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="¡Hola! 👋"
            android:textColor="#111111"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tu entrenamiento empieza aquí"
            android:textColor="#666666"
            android:textSize="18sp" />

        <!-- Tarjeta rutina -->
        <LinearLayout
            android:id="@+id/cardRutina"
            android:layout_width="match_parent"
            android:layout_height="210dp"
            android:layout_marginTop="26dp"
            android:background="@drawable/bg_pink_gradient"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_tag_pink"
                android:paddingStart="14dp"
                android:paddingTop="7dp"
                android:paddingEnd="14dp"
                android:paddingBottom="7dp"
                android:text="🔥 Rutina recomendada"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtRutinaNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Pierna y glúteo"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtRutinaInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="5 ejercicios · 45 min"
                android:textColor="#FFFFFF"
                android:textSize="19sp" />

            <TextView
                android:layout_width="150dp"
                android:layout_height="48dp"
                android:layout_marginTop="22dp"
                android:background="@drawable/bg_button_white"
                android:gravity="center"
                android:text="Ver rutina  →"
                android:textColor="#FF2D7A"
                android:textSize="17sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Explora -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Explora"
            android:textColor="#111111"
            android:textSize="26sp"
            android:textStyle="bold" />

        <!-- Rutinas y clases -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/btnRutinas"
                android:layout_width="0dp"
                android:layout_height="155dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_soft_pink"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:background="@drawable/bg_circle_strong_pink"
                    android:gravity="center"
                    android:text="🏋️"
                    android:textSize="28sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Rutinas"
                    android:textColor="#111111"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Entrena a tu ritmo"
                    android:textColor="#666666"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnClases"
                android:layout_width="0dp"
                android:layout_height="155dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_card_soft_pink"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:background="@drawable/bg_circle_strong_pink"
                    android:gravity="center"
                    android:text="📅"
                    android:textSize="28sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Clases"
                    android:textColor="#111111"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reserva tu plaza"
                    android:textColor="#666666"
                    android:textSize="15sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Mi gimnasio -->
        <LinearLayout
            android:id="@+id/btnGimnasios"
            android:layout_width="match_parent"
            android:layout_height="112dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card_soft_pink"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="20dp">

            <TextView
                android:layout_width="62dp"
                android:layout_height="62dp"
                android:background="@drawable/bg_circle_strong_pink"
                android:gravity="center"
                android:text="🏢"
                android:textSize="30sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mi gimnasio"
                    android:textColor="#111111"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Información, horarios y contacto"
                    android:textColor="#666666"
                    android:textSize="15sp" />
            </LinearLayout>

            <TextView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_button_white"
                android:gravity="center"
                android:text="→"
                android:textColor="#FF2D7A"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Próxima clase -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Próxima clase"
            android:textColor="#111111"
            android:textSize="24sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="105dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="28dp"
            android:background="@drawable/bg_card_white"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="18dp">

            <TextView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/bg_circle_light_pink"
                android:gravity="center"
                android:text="🧘"
                android:textSize="30sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtClaseNombre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Yoga"
                    android:textColor="#111111"
                    android:textSize="21sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtClaseGimnasio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mi gimnasio"
                    android:textColor="#666666"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/txtClaseHorario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hoy, 18:00 · Sala 2"
                    android:textColor="#666666"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:layout_width="105dp"
                android:layout_height="46dp"
                android:background="@drawable/bg_button_pink"
                android:gravity="center"
                android:text="Ver clases"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>