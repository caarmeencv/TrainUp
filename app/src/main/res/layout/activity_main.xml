<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:layout_width="130dp"
            android:layout_height="90dp"
            android:layout_gravity="center"
            android:src="@drawable/logo_trainup"
            android:contentDescription="Logo TrainUp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¡Hola, Carmen! 👋"
            android:textColor="#FF2D7A"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Listo para entrenar hoy"
            android:textColor="#111111"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sigue tu progreso y alcanza tus objetivos."
            android:textColor="#777777"
            android:textSize="16sp"
            android:layout_marginTop="6dp" />

        <!-- Tarjeta progreso -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_rosa"
            android:padding="20dp"
            android:layout_marginTop="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tu progreso"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Esta semana"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginTop="18dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="3\nEntrenos"
                    android:gravity="center"
                    android:textColor="#111111"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="4h 30m\nTiempo"
                    android:gravity="center"
                    android:textColor="#111111"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="12\nEjercicios"
                    android:gravity="center"
                    android:textColor="#111111"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Accesos rápidos"
            android:textColor="#111111"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="28dp" />

        <!-- Accesos rápidos -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:layout_marginTop="14dp">

            <Button
                android:id="@+id/btnRutinas"
                android:layout_width="0dp"
                android:layout_height="95dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:text="Rutinas\nCrea o sigue rutinas"
                android:textAllCaps="false"
                android:background="@drawable/bg_card"
                android:textColor="#111111" />

            <Button
                android:id="@+id/btnClases"
                android:layout_width="0dp"
                android:layout_height="95dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:text="Clases\nReserva tus clases"
                android:textAllCaps="false"
                android:background="@drawable/bg_card"
                android:textColor="#111111" />

            <Button
                android:id="@+id/btnGimnasios"
                android:layout_width="0dp"
                android:layout_height="95dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:text="Gimnasios\nEncuentra gimnasio"
                android:textAllCaps="false"
                android:background="@drawable/bg_card"
                android:textColor="#111111" />

            <Button
                android:id="@+id/btnProgreso"
                android:layout_width="0dp"
                android:layout_height="95dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:text="Progreso\nVer estadísticas"
                android:textAllCaps="false"
                android:background="@drawable/bg_card"
                android:textColor="#111111" />
        </GridLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Próximas clases"
            android:textColor="#111111"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="26dp" />

        <!-- Clase 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card"
            android:padding="14dp"
            android:layout_marginTop="14dp">

            <ImageView
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:src="@drawable/yoga"
                android:scaleType="centerCrop" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Yoga"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#111111" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fit Coruña Centro"
                    android:textSize="15sp"
                    android:textColor="#666666" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hoy, 18:00 - 19:00"
                    android:textSize="15sp"
                    android:textColor="#666666" />
            </LinearLayout>
        </LinearLayout>

        <!-- Rutina de hoy -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rutina de hoy"
            android:textColor="#111111"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="26dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="30dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pecho y Tríceps"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#111111" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="6 ejercicios · 45-60 min"
                android:textSize="15sp"
                android:textColor="#666666"
                android:layout_marginTop="6dp" />

            <ProgressBar
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:layout_marginTop="14dp"
                android:progress="60"
                style="?android:attr/progressBarStyleHorizontal" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>