<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_card_soft_pink"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/txtNombreClase"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Yoga"
        android:textColor="#111111"
        android:textSize="21sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtFechaHora"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="2026-06-11 · 18:00"
        android:textColor="#666666"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/txtDatosClase"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="Sala 1 · Monitor Carmen · 20 plazas"
        android:textColor="#666666"
        android:textSize="15sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnEditarClase"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_white"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="Editar"
            android:textColor="#FF2D7A"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnEliminarClase"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_pink"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="Eliminar"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>