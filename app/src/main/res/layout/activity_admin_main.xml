<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F8F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <ImageView
            android:layout_width="130dp"
            android:layout_height="90dp"
            android:layout_gravity="center"
            android:src="@drawable/logo_trainup"
            android:contentDescription="Logo TrainUp" />

        <TextView
            android:id="@+id/txtSaludo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¡Hola! 👋"
            android:textColor="#FF2D7A"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Panel de administración"
            android:textColor="#111111"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- Estadísticas rápidas -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Resumen del gimnasio"
            android:textColor="#111111"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="28dp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:layout_marginTop="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_card"
                android:padding="12dp">

                <TextView
                    android:id="@+id/txtTotalMiembros"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="128"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#FF2D7A" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Miembros activos"
                    android:textSize="13sp"
                    android:textColor="#888888" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_card"
                android:padding="12dp">

                <TextView
                    android:id="@+id/txtTotalClases"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="8"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#FF2D7A" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clases esta semana"
                    android:textSize="13sp"
                    android:textColor="#888888" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_card"
                android:padding="12dp">

                <TextView
                    android:id="@+id/txtReservasHoy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="34"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#FF2D7A" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reservas hoy"
                    android:textSize="13sp"
                    android:textColor="#888888" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_card"
                android:padding="12dp">

                <TextView
                    android:id="@+id/txtOcupacionMedia"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="76%"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#FF2D7A" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ocupación media"
                    android:textSize="13sp"
                    android:textColor="#888888" />
            </LinearLayout>

        </GridLayout>

        <!-- Gestión de clases -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="28dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Gestión de clases"
                android:textColor="#111111"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnNuevaClase"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ Nueva clase"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="#FF2D7A"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp" />
        </LinearLayout>

        <!-- Clase gestionable 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:layout_marginTop="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtClase1Nombre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Yoga"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#111111" />

                <TextView
                    android:id="@+id/txtClase1Horario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hoy, 18:00 - 19:00"
                    android:textSize="13sp"
                    android:textColor="#FF2D7A"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />

                <TextView
                    android:id="@+id/txtClase1Apuntados"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12 / 20 apuntados"
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnEditarClase1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Editar"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textColor="#FF2D7A"
                android:background="@drawable/bg_card"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnEliminarClase1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Eliminar"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="#FF2D7A" />
        </LinearLayout>

        <!-- Clase gestionable 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_card"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtClase2Nombre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Spinning"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#111111" />

                <TextView
                    android:id="@+id/txtClase2Horario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mañana, 10:00 - 11:00"
                    android:textSize="13sp"
                    android:textColor="#FF2D7A"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />

                <TextView
                    android:id="@+id/txtClase2Apuntados"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="20 / 20 apuntados"
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnEditarClase2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Editar"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textColor="#FF2D7A"
                android:background="@drawable/bg_card"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnEliminarClase2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Eliminar"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="#FF2D7A" />
        </LinearLayout>

        <!-- Info del gimnasio -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="28dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mi gimnasio"
                android:textColor="#111111"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnEditarGimnasio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Editar info"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="#FF2D7A"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="30dp">

            <TextView
                android:id="@+id/txtGimnasioNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fit Coruña Centro"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#111111" />

            <TextView
                android:id="@+id/txtGimnasioDireccion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Calle Real 14, A Coruña"
                android:textSize="14sp"
                android:textColor="#888888"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/txtGimnasioHorario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🕐 Lun–Vie: 7:00–22:00 · Sáb: 9:00–15:00"
                android:textSize="14sp"
                android:textColor="#888888"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/txtGimnasioTelefono"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📞 +34 981 000 000"
                android:textSize="14sp"
                android:textColor="#888888"
                android:layout_marginTop="4dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>