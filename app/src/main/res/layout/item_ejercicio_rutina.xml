<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_card"
    android:orientation="horizontal"
    android:padding="14dp">

    <ImageView
        android:id="@+id/imgEjercicio"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:contentDescription="Imagen ejercicio"
        android:scaleType="centerCrop"
        android:src="@drawable/logo_trainup" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtNombreEjercicio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sentadilla"
            android:textColor="#111111"
            android:textSize="19sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtGrupoMuscular"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Piernas"
            android:textColor="#FF2D7A"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtDescripcionEjercicio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:text="Ejercicio para trabajar piernas y glúteos."
            android:textColor="#777777"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtDetalleEjercicio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="3 series x 12 repeticiones"
            android:textColor="#111111"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>